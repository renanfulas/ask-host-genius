# Local development proxy used by Vite for /web/chat and /web/feedback.
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8765

# Keep empty for same-origin requests through the Vite proxy.
# For a separate frontend deployment, set the public backend URL only after
# configuring a restricted CORS allowlist in supportFAQagent.
VITE_API_BASE_URL=
